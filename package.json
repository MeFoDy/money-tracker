    "alpinejs": "^3.14.0",
    "better-sqlite3": "^12.10.0",
    "chart.js": "^4.4.2",
    "chartjs-plugin-datalabels": "^2.2.0",
    "commander": "^12.0.0",
    "csv-parse": "^5.5.5",
