  "version": "1.0.0",
  "description": "Finance tracker with bank statement CSV import, web SPA and CLI",
  "type": "module",
  "main": "src/web/server.js",
  "bin": {
    "money-tracker-cli": "src/cli/cli.js"
  },
  "scripts": {
    "web": "node src/web/server.js",
    "cli": "node src/cli/cli.js",
    "test": "node --test tests/*.test.js",
